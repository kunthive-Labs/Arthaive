# Supabase - get these from https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Resend for deal submission email notifications
RESEND_API_KEY=re_your_key

# Optional: Admin email for submission notifications
ADMIN_EMAIL=admin@yourdomain.com

# App URL (used for OG tags, sitemap)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
