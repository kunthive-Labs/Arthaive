# Supabase - get these from https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin panel access — comma-separated list of authorized admin emails
ADMIN_EMAILS=admin@yourdomain.com

# Anthropic API — required for Phase 7 AI features (trend summaries, NL search)
ANTHROPIC_API_KEY=sk-ant-your-key

# App URL (used for OG tags, sitemap)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Build / display metadata. NEXT_PUBLIC_BASE_URL is the canonical origin used
# for absolute links; NEXT_PUBLIC_APP_VERSION is surfaced in the UI / footer.
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# ---------------------------------------------------------------------------
# Optional infrastructure. Both rate limiting and Sentry GRACEFULLY NO-OP when
# their vars are unset — the code falls back to a pass-through, so the app
# still runs locally without any of the values below.
# ---------------------------------------------------------------------------

# Upstash Redis — backs API rate limiting. If unset, rate limiting is disabled
# (all requests allowed). Get these from https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Sentry — error & performance monitoring. If the DSN is unset, Sentry is a
# no-op at runtime AND build time (no source maps uploaded). Get these from
# https://sentry.io project settings.
NEXT_PUBLIC_SENTRY_DSN=https://your-public-key@o0.ingest.sentry.io/0
SENTRY_DSN=https://your-public-key@o0.ingest.sentry.io/0
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
# Auth token is only needed in CI/CD to upload source maps during the build.
SENTRY_AUTH_TOKEN=your-sentry-auth-token
